---
import Home from '../../components/Home.astro';
import { languages, defaultLang, type Lang } from '../../i18n/ui';

// Varsayılan dışındaki diller için statik rotalar: /tr/, /en/, /ar/, /fa/
// (en/ar/fa iskelet — NO'ya fallback; ar/fa RTL ile render olur.)
export function getStaticPaths() {
  return (Object.keys(languages) as Lang[])
    .filter((l) => l !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
---

<Home lang={lang} />
