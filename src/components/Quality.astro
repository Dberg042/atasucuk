---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section quality" aria-labelledby="quality-heading">
  <div class="container">
    <div class="quality__head">
      <h2 id="quality-heading" class="section-head__title">{t('quality.title')}</h2>
      <div class="quality__rule" aria-hidden="true"></div>
    </div>

    <div class="pillars">
      <article class="pillar">
        <div class="pillar__icon">
          <svg class="ico ico-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5 22h14"></path><path d="M5 2h14"></path><path d="M17 22v-4.172a2 2 0 0 0-.586-1.414L12 12l-4.414 4.414A2 2 0 0 0 7 17.828V22"></path><path d="M7 2v4.172a2 2 0 0 0 .586 1.414L12 12l4.414-4.414A2 2 0 0 0 17 6.172V2"></path></svg>
        </div>
        <h3 class="pillar__title">{t('quality.p1_title')}</h3>
        <p class="pillar__text">{t('quality.p1_text')}</p>
      </article>

      <article class="pillar">
        <div class="pillar__icon">
          <svg class="ico ico-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12.5" cy="8.5" r="2.5"></circle><path d="M12.5 2a6.5 6.5 0 0 0-6.22 4.6c-1.1 3.13-.78 3.9-3.18 6.08A3 3 0 0 0 5 18c4 0 8.4-1.8 11.4-4.3A6.5 6.5 0 0 0 12.5 2Z"></path><path d="m18.5 6 2.19 4.5a6.48 6.48 0 0 1 .31 2 6.49 6.49 0 0 1-2.6 5.2C15.4 20.2 11 22 7 22a3 3 0 0 1-2.68-1.66L2.4 16.5"></path></svg>
        </div>
        <h3 class="pillar__title">{t('quality.p2_title')}</h3>
        <p class="pillar__text">{t('quality.p2_text')}</p>
      </article>

      <article class="pillar">
        <div class="pillar__icon">
          <svg class="ico ico-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"></path></svg>
        </div>
        <h3 class="pillar__title">{t('quality.p3_title')}</h3>
        <p class="pillar__text">{t('quality.p3_text')}</p>
      </article>
    </div>
  </div>
</section>
