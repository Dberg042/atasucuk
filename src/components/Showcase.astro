---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="showcase" aria-label="Ata Sucuk">
  <div class="container">
    <div class="showcase__frame">
      <img class="showcase__img" src="/assets/middle.png" alt={t('showcase.alt')} width="1536" height="1024" loading="lazy" />
    </div>
  </div>
</section>
