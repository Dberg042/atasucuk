# ============================================================
# ATA SUCUK — ENV ŞABLONU  (bu dosya git'e gider — gerçek key YAZMA)
# Kullanım: cp .env.example .env  →  .env dosyasını doldur
#
# KURAL: PUBLIC_ ile başlayanlar → frontend / CF Pages env
#        Geri kalanlar            → sadece CF Worker secrets
# ============================================================

# ------------------------------------------------------------
# SUPABASE — supabase.com → projen → Settings → API
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # ASLA frontend'e koyma

# ------------------------------------------------------------
# CLOUDFLARE — dash.cloudflare.com → My Profile → API Tokens
# Template: "Edit Cloudflare Workers"
# ------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# ------------------------------------------------------------
# TURNSTILE — dash.cloudflare.com → Turnstile → Add site
# ------------------------------------------------------------
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key   # public, frontend'e gider
TURNSTILE_SECRET_KEY=your-turnstile-secret-key       # sadece Worker

# ------------------------------------------------------------
# MAIL — resend.com → API Keys → Create API Key
# ------------------------------------------------------------
RESEND_API_KEY=your-resend-api-key
MAIL_FROM=noreply@atasucuk.no

# ------------------------------------------------------------
# TOKEN İMZALAMA — terminalde: openssl rand -hex 32
# ------------------------------------------------------------
CONFIRM_TOKEN_SECRET=your-64-char-hex-secret

# ------------------------------------------------------------
# UYGULAMA
# ------------------------------------------------------------
PUBLIC_SITE_URL=https://atasucuk.no
PUBLIC_API_URL=https://api.atasucuk.no
